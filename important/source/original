-- ライブラリの読み込み（source.txtの内容が実行されている前提）
local OrionLib = loadstring(game:HttpGet(('https://raw.githubusercontent.com/shlexware/Orion/main/source')))()

-- 1. ウィンドウを作成
local Window = OrionLib:MakeWindow({
    Name = "My Custom UI", 
    HidePremium = false, 
    SaveConfig = true, 
    ConfigFolder = "OrionTest",
    IntroText = "Welcome to Orion"
})

-- 2. タブを作成
local Tab = Window:MakeTab({
    Name = "Main Functions",
    Icon = "rbxassetid://4483345998",
    PremiumOnly = false
})

-- 3. 要素を追加
-- ラベル
Tab:AddLabel("Game Settings")

-- ボタン
Tab:AddButton({
    Name = "Kill All",
    Callback = function()
        print("Kill All button clicked!")
    end    
})

-- トグル（ON/OFFスイッチ）
Tab:AddToggle({
    Name = "Auto Farm",
    Default = false,
    Callback = function(Value)
        print("Auto Farm is now: ", Value)
    end    
})

-- 初期化
OrionLib:Init()
